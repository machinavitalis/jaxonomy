{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "pytest",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "purpose": [
                "debug-test"
            ],
        },
        {
            "name": "jaxonomy_cli run",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/jaxonomy/cli/jaxonomy_cli.py",
            "args": [
                "run",
                "--model",
                "${file}",
            ],
            "justMyCode": true,
            "cwd": "${fileDirname}",
        },
        {
            "name": "jaxonomy_cli optimize",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/jaxonomy/cli/jaxonomy_cli.py",
            // You may need to add --model and/or --request here
            "args": ["optimize"],
            "justMyCode": true,
            "cwd": "${fileDirname}",
        }
    ]
}

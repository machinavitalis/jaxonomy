# Pure Python dependencies
# Marked as compatible to the micro versions
click ~= 8.1
dataclasses-json ~= 0.6
dataclasses-jsonschema ~= 2.16
networkx ~= 3.1
numpy >= 2.0
scipy ~= 1.13
sympy ~= 1.13
ts-type ~= 0.2
simpleeval ~= 0.9

# Core JAX dependencies
# These are marked as compatible to the minor version because of breaking
# changes between JAX minor versions (e.g. 0.4.x → 0.5.x, 0.8.x → 0.9.x).
diffrax ~= 0.7.2; platform_system != "Emscripten"
equinox ~= 0.13.6; platform_system != "Emscripten"
fmpy ~= 0.3.19; platform_system != "Emscripten"
jax ~= 0.9.1; platform_system != "Emscripten"
jaxlib ~= 0.9.1; platform_system != "Emscripten"
jaxtyping ~= 0.3.9; platform_system != "Emscripten"
optax ~= 0.2.8; platform_system != "Emscripten"
brax ~= 0.14.1; platform_system != "Emscripten"
# jaxopt is a transitive dependency of brax (brax.generalized.constraint imports it
# directly). Not used by jaxonomy itself. Remove once brax drops the dependency.
jaxopt ~= 0.8.5; platform_system != "Emscripten"

# Other dependencies not compatible with WASM
requests ~= 2.32; platform_system != "Emscripten"
cloudpickle ~= 3.0; platform_system != "Emscripten"
evosax ~= 0.1.6; platform_system != "Emscripten"
opencv-python ~= 4.13.0; platform_system != "Emscripten"

# Python 3.10 compatibility
StrEnum ~= 0.4.15; python_version < "3.11"

# Pyodide/WASM - to be installed separately
jaxlite; platform_system == "Emscripten"

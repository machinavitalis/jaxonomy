<mujoco model="triple_pendulum_cart">
  <!-- Planar cart + three serial links in the xz plane (hinge axis along +y). -->
  <compiler angle="radian" autolimits="true"/>
  <!-- Slightly softened gravity for this tutorial so LQR has a practical basin (still nontrivial). -->
  <option timestep="0.005" gravity="0 0 -9.81" integrator="RK4"/>

  <default>
    <geom type="capsule" size="0.015" rgba="0.2 0.5 0.9 1"/>
    <joint damping="0.08" armature="0.02"/>
    <motor ctrllimited="true" ctrlrange="-300 300" gear="1"/>
  </default>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="1 1 1"/>
    <geom name="floor" type="plane" size="2 2 0.05" rgba="0.85 0.85 0.88 1"/>

    <body name="cart" pos="0 0 0.05">
      <joint name="slider" type="slide" axis="1 0 0" limited="true" range="-2.5 2.5" damping="0.5"/>
      <geom name="cart_geom" type="box" size="0.12 0.06 0.04" mass="0.85" rgba="0.3 0.3 0.35 1"/>

      <!-- Shorter, lighter links: easier LQR basin while keeping three DOF (tutorial-scale plant). -->
      <body name="link1" pos="0 0 0.04">
        <joint name="hinge1" type="hinge" axis="0 1 0"/>
        <geom fromto="0 0 0 0 0 0.10" mass="0.035"/>
        <body name="link2" pos="0 0 0.10">
          <joint name="hinge2" type="hinge" axis="0 1 0"/>
          <geom fromto="0 0 0 0 0 0.09" mass="0.028"/>
          <body name="link3" pos="0 0 0.09">
            <joint name="hinge3" type="hinge" axis="0 1 0"/>
            <geom fromto="0 0 0 0 0 0.08" mass="0.022"/>
            <site name="tip" pos="0 0 0.08" size="0.015" rgba="1 0.2 0.2 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="cart_force" joint="slider"/>
  </actuator>

  <keyframe>
    <key name="upright" qpos="0 0 0 0" qvel="0 0 0 0" ctrl="0"/>
    <!-- Small tilt on the first link (radians) for regulation demos -->
    <key name="tilted" qpos="0 0.04 0 0" qvel="0 0 0 0" ctrl="0"/>
    <!-- Links nominally along +z at q=0 (up); ~pi on each hinge hangs the chain downward in xz -->
    <key name="hanging" qpos="0 3.14159 3.14159 3.14159" qvel="0 0 0 0" ctrl="0"/>
  </keyframe>
</mujoco>
